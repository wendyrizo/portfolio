---
import ArrowUpRight from "./icons/ArrowUpRight.astro";
import Badge from "./Badge.astro";
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article
  class="grid md:grid-cols-2 gap-4 border border-slate-800 rounded-2xl p-4"
>
  <figure>
    <img
      src={project.image}
      alt={`${project.title} preview`}
      class="aspect-video rounded-xl object-cover"
      loading="lazy"
    />
  </figure>

  <div class="space-y-3">
    <header>
      <h3 class="text-lg font-semibold">
        <a
          href={project.link}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-0.5 hover:underline"
        >
          {project.title}
          <ArrowUpRight
            class="size-5 opacity-50 group-hover:translate-x-0.5 group-hover:opacity-100 transition-all duration-150"
          />
        </a>
      </h3>
    </header>

    <p class="text-slate-200 text-pretty">{project.description}</p>

    <ul class="flex gap-2 flex-wrap">
      {
        project.stack.map((tech) => (
          <li>
            <Badge class="bg-blue-950/80 text-slate-200 rounded-full">
              {tech}
            </Badge>
          </li>
        ))
      }
    </ul>
  </div>
</article>
