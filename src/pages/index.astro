---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Wendy Rizo">
  <main class="flex justify-center items-center">
    <div
      class="w-[80%] max-w-3xl text-neutral-600 font-[380] mt-[100px] lg:mt-[180px]"
    >
      <div>
        <h1 class="text-neutral-900 pb-6 text-xl">
          We<span class="italic">n</span>dy Ri<span class="italic">z</span>o
        </h1>
        <p class="leading-[25px] pb-4">
          Estudiante de Ingeniería en Ciencias Computacionales con sede en
          Jalisco, MX.
        </p>
        <p class="leading-[25px] pb-4">
          Actualmente enfocada en mis estudios y trabajando en proyectos
          personales.
        </p>
        <div class="mt-6">
          <p class="leading-[25px] pb-4">
            Echa un vistazo a mi último
            <a
              href="/work"
              class="text-neutral-900 underline bg-blue-200 hover:text-neutral-500"
              >trabajo.</a
            >
          </p>
          <p class="leading-[25px] pb-4">
            Para consultas profesionales, vea mi <a
              href="https://drive.google.com/file/d/17lEG31MFW3aoGoBHrdDBJOPLshewlRRN/view?usp=drive_link"
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-900 underline hover:text-neutral-500">CV</a
            > o
            <a
              href="mailto:wendymtnezrizo@gmail.com"
              class="text-neutral-900 underline hover:text-neutral-500 transition"
            >
              póngase en contacto.
            </a>
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>
