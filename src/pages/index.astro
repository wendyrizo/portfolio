---
import Layout from "../layouts/Layout.astro";
import "@fontsource-variable/playfair-display/wght-italic.css";
---

<Layout title="My First Portfolio.">
	<main>
		<section
			class="flex items-center justify-center min-h-screen text-center"
		>
			<div>
				<p class="uppercase opacity-70">
					Computer Science & Engineering Student
				</p>
				<h1>
					<span class="block text-7xl md:text-9xl">
						We<span class="italic">n</span>dy Ri<span class="italic"
							>z</span
						>o
					</span>
				</h1>
			</div>
		</section>
		<section id="work">
			<h2 class="text-5xl text-center md:text-7xl">Work</h2>
			<div>
				<h3 class="text-2xl p-5 italic">
					<a href="/mobypay">mobypay</a>
				</h3>
				<h3 class="text-2xl p-5 italic"><a href="/">stocknet</a></h3>
			</div>
		</section>
		<section id="about">
			<h2 class="text-5xl text-center md:text-7xl">About</h2>
			<p>
				Soy estudiante de Ingeniería en Ciencias Computaciones en la
				Universida de Guadalajara.
			</p>
		</section>
	</main>
</Layout>
