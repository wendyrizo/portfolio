---
import Layout from "../layouts/Layout.astro";
const projects = [
  {
    id: "tterm",
    name: "tterm",
    description: "A command-line task organizer built with Python.",
  },
  {
    id: "otro-proyecto",
    name: "Otro Proyecto",
    description: "Another project description here.",
  },
];
---

<Layout title="Work">
  <section class="flex justify-center items-center">
    <div
      class="w-[80%] max-w-3xl text-neutral-600 font-[380] mt-[100px] lg:mt-[180px]"
    >
      <div>
        <h2 class="text-neutral-900 pb-6 text-xl">
          Wo<span class="italic">rk</span>
        </h2>
        <p class="leading-[25px] pb-4">
          No es mucho, pero es trabajo honesto :)
        </p>
      </div>
      <div class="space-y-4">
        {
          projects.map((project) => (
            <article key={project.id}>
              <h3 class="text-neutral-800 italic font-medium">
                {project.name}
              </h3>
              <p>{project.description}</p>
              <a
                href={`/projects/${project.id}`}
                class="underline hover:text-blue-500 transition"
              >
                View project →
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
